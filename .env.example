# Pressbox API keys — get these from your providers and put in ~/.hermes/.env
# DO NOT commit real keys to git.

# Primary: Mistral
# Get key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Fallback: TokenRouter (for MiniMax-M3)
# Get key at: https://tokenrouter.com/
TOKENROUTER_API_KEY=your_tokenrouter_api_key
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Telegram bot (for cron notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Threads API (Meta Graph API)
THREADS_ACCESS_TOKEN=your_threads_access_token
THREADS_USER_ID=your_threads_user_id
