# Pressbox API keys — put in ~/.hermes/.env
# DO NOT commit real keys to git.

# Primary LLM: Mistral (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key

# Fallback LLM: 9router local router on port 20128 (no key needed)
# Install: https://github.com/9router
# The pipeline auto-falls back to qwen/qwen3-32b via 9router when Mistral fails.

# Telegram bot (for cron notifications to chat)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
